# ── Required ──────────────────────────────────────────────
BNET_CLIENT_ID=
BNET_CLIENT_SECRET=

# ── Optional: MCP endpoint auth (OAuth 2.1) ──────────────
# When set, /mcp requires a Bearer token obtained via OAuth.
# This passphrase is used for the /authorize login page (ChatGPT)
# and as client_secret for client_credentials grants (Warp/CLI).
# Can also be passed directly as a Bearer token for simple clients.
# MCP_AUTH_SECRET=
# MCP_TOKEN_TTL_SECONDS=3600

# ── Optional: persistent OAuth store (PostgreSQL) ───
# When set, tokens/clients/auth codes survive server restarts.
# docker-compose.yml sets this automatically.
# DATABASE_URL=postgresql://wow_mcp:wow_mcp@localhost:5432/wow_mcp

# ── Optional tuning ─────────────────────────────────────────
# LOG_LEVEL=info
# HTTP_TIMEOUT_MS=15000
# HTTP_RETRY_LIMIT=2
# CACHE_TTL_SECONDS=300
# CACHE_SIZE=500
