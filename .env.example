# ── Required ──────────────────────────────────────────────
BNET_CLIENT_ID=
BNET_CLIENT_SECRET=

# ── Optional: MCP endpoint auth ──────────────────────────
# When both are set, /mcp requires a Bearer token from POST /token.
# MCP_CLIENT_ID=
# MCP_CLIENT_SECRET=
# MCP_TOKEN_TTL_SECONDS=3600

# ── Optional tuning ─────────────────────────────────────
# LOG_LEVEL=info
# HTTP_TIMEOUT_MS=15000
# HTTP_RETRY_LIMIT=2
# CACHE_TTL_SECONDS=300
# CACHE_SIZE=500
