{
  "name": "mcp-wow-profile",
  "version": "1.0.0",
  "description": "MCP server exposing World of Warcraft Profile API tools",
  "type": "module",
  "private": true,
  "bin": {
    "mcp-wow-profile": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector dist/index.js",
    "lint": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "got": "^14.4.0",
    "pino": "^9.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
